{
  "OCU_MASTER_KEY": "YOUR_32_BYTE_MASTER_KEY_HERE",
  "vault": {
    "backend": "duckdb",
    "path": "vault_data/vault.db"
  },
  "encryption": {
    "algorithm": "AES-256-GCM",
    "notes": "Ensure the master key is a cryptographically strong 32-byte string. Use HKDF for key derivation as implemented in the Sombra gateway."
  }
}
